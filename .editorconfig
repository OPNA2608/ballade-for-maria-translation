# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120
indent_style = space
indent_size = 2

[*.rkt]
indent_size = 1

[*.txt]
end_of_line = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
max_line_length = unset
indent_style = unset
indent_size = unset
